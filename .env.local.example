# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Salesforce (jsforce direct API)
SF_CLIENT_ID=your-connected-app-consumer-key
SF_CLIENT_SECRET=your-connected-app-consumer-secret
SF_USERNAME=your-sf-username
SF_PASSWORD=your-sf-password
SF_SECURITY_TOKEN=your-sf-security-token

# AI
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Kayako Support Tickets (via Anthropic MCP)
KAYAKO_MCP_URL=https://mcp.csaiautomations.com/kayako-oauth/mcp/?token=your-kayako-mcp-token

# GitHub Actions trigger
GITHUB_TOKEN=your-github-pat
GITHUB_REPO=Jamesstoth/core-renewals-platform-2
